# Cascade Environment Configuration Template
# 复制此文件并重命名为 .env，然后填入你的真实对接口令
# DO NOT COMMIT THE ACTUAL .env FILE!

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# GLM (ZhipuAI) Configuration
GLM_API_KEY=your_glm_api_key_here

# MiniMax Configuration
MINIMAX_API_KEY=your_minimax_api_key_here

# Kimi (Moonshot) Configuration
MOONSHOT_API_KEY=your_kimi_api_key_here

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen (DashScope) Configuration
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# xAI (Grok) Configuration
XAI_API_KEY=your_xai_api_key_here

# Default Model Provider (glm, kimi, minimax, etc.)
CASCADE_DEFAULT_PROVIDER=glm
CASCADE_DEFAULT_MODEL=glm-4-flash
